{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/income.html",
      "destination": "/public/income.html"
    },
    {
      "source": "/expense.html",
      "destination": "/public/expense.html"
    },
    {
      "source": "/",
      "destination": "/public/index.html"
    }
  ]
}