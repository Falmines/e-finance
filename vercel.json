{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/income.html",
      "dest": "/public/income.html"
    },
    {
      "src": "/expense.html",
      "dest": "/public/expense.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}